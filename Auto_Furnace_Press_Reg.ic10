alias Furnace d0
alias FurnacePress r0

define FurnacePressureSafteyLimit 60000

Start:
  l FurnacePress Furnace Pressure
  bge FurnacePress FurnacePressureSafteyLimit PressureHigh
  yield
j Start

PressureHigh:
  s Furnace SettingOutput 10 # Turn on furnace output to dump gas at 10L
  l FurnacePress Furnace Pressure
  bge FurnacePress FurnacePressureSafteyLimit PressureHigh
  s Furnace SettingOutput 0
j Start